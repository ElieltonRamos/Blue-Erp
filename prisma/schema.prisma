generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// Seus models aqui
model Restaurante {
  id        Int      @id @default(autoincrement())
  nome      String
  cnpj      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
