{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Blue Erp",
  "mainBinaryName": "blue-erp",
  "version": "0.8.5",
  "identifier": "com.bluetech.blue-erp",
  "build": {
    "frontendDist": "../dist/frontend/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "npm start",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Blue Erp",
        "width": 800,
        "height": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
