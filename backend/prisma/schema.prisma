generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Company {
  id                        Int       @id @default(autoincrement())
  cnpj                      String    @unique // SEM formatação (12345678000190)
  corporateName             String    @map("corporate_name") // Razão social
  tradeName                 String    @map("trade_name") // Nome fantasia
  stateRegistration         String    @map("state_registration") // Inscrição estadual
  taxRegime                 String    @map("tax_regime")
  street                    String
  number                    String
  complement                String?
  neighborhood              String
  city                      String
  cityCode                  String    @map("city_code") // IBGE
  state                     String // UF
  zipCode                   String    @map("zip_code") // CEP
  phone                     String
  email                     String?
  nfceSeries                String    @map("nfce_series")
  nfceCurrentNumber         Int       @default(1) @map("nfce_current_number")
  nfceEnvironment           String    @default("staging") @map("nfce_environment") // production|staging
  nfceCsc                   String    @map("nfce_csc")
  nfceCscId                 String    @map("nfce_csc_id")
  certificatePath           String    @map("certificate_path")
  certificatePassword       String    @map("certificate_password")
  certificateExpirationDate DateTime? @map("certificate_expiration_date")
  ibptVersion               String    @default("4.0") @map("ibpt_version")
  licenseKey                String    @map("license_key")
  licenseToken              String    @map("license_token")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  cpf       String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cpf])
  @@index([phone])
  @@index([active])
  @@map("clients")
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  password  String // Hash bcrypt
  role      String  @default("USER") // ADMIN, MANAGER, WAITER, CASHIER, KITCHEN
  active    Boolean @default(true)
  workplace String

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  @@index([role])
  @@index([active])
  @@map("users")
}


model Ibpt {
  id           Int     @id @default(autoincrement())
  ncm          String
  aliqFederal  Float   @map("aliq_federal")   // Alíquota Federal
  aliqEstadual Float   @map("aliq_estadual")  // Alíquota Estadual  
  aliqMunicipal Float  @map("aliq_municipal") // Alíquota Municipal
  version      String  @default("4.0") @map("version") // Versão IBPT

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([ncm])
  @@index([version])
  @@map("ibpt")
}

model Expense {
  id           Int      @id @default(autoincrement())
  supplier     String   @map("supplier")         // Fornecedor
  description  String?  @map("description")      // Descrição (opcional)
  value        Decimal  @map("value")            // Valor (Decimal para precisão financeira)
  datePayment  DateTime @map("date_payment")     // Data de pagamento
  status       String   @map("status")           // 'Pago' | 'Pendente' | 'Atrasado'

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  @@index([supplier])
  @@index([status])
  @@index([datePayment])
  @@map("expenses")
}
