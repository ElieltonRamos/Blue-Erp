generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Unit {
  UN
  KG
  LT
  MT
  CX
  ML
  GR
  DZ
}

enum ProductType {
  MANUFACTURED
  RESALE
  SEMI_MANUFACTURED
}

enum FiscalStatus {
  PENDENTE
  EMITIDA
  CANCELADA
  ERRO
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELED
  PAID
}

enum OrderType {
  DINE_IN
  DELIVERY
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

model Company {
  id                        Int       @id @default(autoincrement())
  cnpj                      String    @unique
  corporateName             String    @map("corporate_name")
  tradeName                 String    @map("trade_name")
  stateRegistration         String    @map("state_registration")
  taxRegime                 String    @map("tax_regime")
  street                    String
  number                    String
  complement                String?
  neighborhood              String
  city                      String
  cityCode                  String    @map("city_code")
  state                     String
  zipCode                   String    @map("zip_code")
  phone                     String
  email                     String?
  nfceSeries                String    @map("nfce_series")
  nfceCurrentNumber         Int       @default(1) @map("nfce_current_number")
  nfceEnvironment           String    @default("staging") @map("nfce_environment")
  nfceCsc                   String    @map("nfce_csc")
  nfceCscId                 String    @map("nfce_csc_id")
  certificatePath           String    @map("certificate_path")
  certificatePassword       String    @map("certificate_password")
  certificateExpirationDate DateTime? @map("certificate_expiration_date")
  ibptVersion               String    @default("4.0") @map("ibpt_version")
  licenseKey                String    @map("license_key")
  licenseToken              String?   @map("license_token") @db.Text
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  @@map("companies")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  cpf       String?  @unique
  active    Boolean  @default(true)
  sales     Sale[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cpf])
  @@index([phone])
  @@index([active])
  @@map("clients")
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  role      String    @default("USER")
  active    Boolean   @default(true)
  workplace String
  sales     Sale[]
  orders    Order[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([role])
  @@index([active])
  @@map("users")
}

model Ibpt {
  id               Int      @id @default(autoincrement())
  ncm              String
  federalTaxRate   Float    @map("federal_tax_rate")
  stateTaxRate     Float    @map("state_tax_rate")
  municipalTaxRate Float    @map("municipal_tax_rate")
  version          String   @default("4.0")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([ncm])
  @@index([version])
  @@map("ibpt")
}

model Expense {
  id          Int       @id @default(autoincrement())
  supplier    String
  description String?
  value       Decimal   @db.Decimal(10, 2)
  datePayment DateTime  @map("date_payment")
  status      String
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([supplier])
  @@index([status])
  @@index([datePayment])
  @@map("expenses")
}

model ProductionLocation {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  description String?
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  tables      Table[]

  @@index([active])
  @@index([order])
  @@map("production_locations")
}

model Product {
  id                 Int               @id @default(autoincrement())
  name               String
  code               String            @unique
  productionLocation String?           @map("production_location")
  price              Decimal           @db.Decimal(10, 2)
  costPrice          Decimal           @map("cost_price") @db.Decimal(10, 2)
  extraCosts         Decimal           @default(0) @map("extra_costs") @db.Decimal(10, 2)
  ncm                String
  cest               String?
  origin             Int
  csosn              String?
  cst                String?
  icmsRate           Decimal?          @map("icms_rate") @db.Decimal(5, 2)
  cstPis             String?           @map("cst_pis")
  pisRate            Decimal?          @map("pis_rate") @db.Decimal(5, 2)
  cstCofins          String?           @map("cst_cofins")
  cofinsRate         Decimal?          @map("cofins_rate") @db.Decimal(5, 2)
  federalTaxRate     Decimal?          @map("federal_tax_rate") @db.Decimal(5, 2)
  stateTaxRate       Decimal?          @map("state_tax_rate") @db.Decimal(5, 2)
  municipalTaxRate   Decimal?          @map("municipal_tax_rate") @db.Decimal(5, 2)
  unit               Unit
  quantity           Decimal           @default(0) @db.Decimal(10, 3)
  minStock           Decimal?          @map("min_stock") @db.Decimal(10, 3)
  active             Boolean           @default(true)
  productType        ProductType       @default(RESALE) @map("product_type")
  categoryId         Int?              @map("category_id")
  category           Category?         @relation(fields: [categoryId], references: [id])
  compositionItems   CompositionItem[] @relation("ProductComposition")
  usedInCompositions CompositionItem[] @relation("SubProductComposition")
  preparationSteps   PreparationStep[]
  saleItems          SaleItem[]
  orderItems         OrderItem[]
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([code])
  @@index([ncm])
  @@index([active])
  @@index([categoryId])
  @@map("products")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("categories")
}

model Order {
  id                Int         @id @default(autoincrement())
  type              OrderType
  locationId        String      @map("location_id")
  customerName      String?
  table             String?
  address           String?
  status            OrderStatus @default(OPEN)
  total             Decimal     @db.Decimal(10, 2)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  kitchenSentAt     DateTime?   @map("kitchen_sent_at")
  kitchenReadyAt    DateTime?   @map("kitchen_ready_at")
  finishedAt        DateTime?   @map("finished_at")
  deliveredAt       DateTime?   @map("delivered_at")
  tableOccupiedUtil DateTime?   @map("table_occupied_until")
  operatorId        Int?        @map("operator_id")
  operator          User?       @relation(fields: [operatorId], references: [id])
  items             OrderItem[]
  tableRef          Table?

  @@index([status])
  @@index([locationId])
  @@index([type])
  @@index([operatorId])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id             Int               @id @default(autoincrement())
  code           String
  name           String
  quantity       Decimal           @db.Decimal(10, 3)
  unitPrice      Decimal           @map("unit_price") @db.Decimal(10, 2)
  total          Decimal           @db.Decimal(10, 2)
  kitchenReadyAt DateTime?         @map("kitchen_ready_at")
  orderId        Int               @map("order_id")
  order          Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      Int               @map("product_id")
  product        Product           @relation(fields: [productId], references: [id])
  productions    OrderProduction[]
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderProduction {
  id                 Int              @id @default(autoincrement())
  orderItemId        Int              @map("order_item_id")
  orderItem          OrderItem        @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  productionLocation String           @map("production_location")
  status             ProductionStatus @default(PENDING)
  quantityRequested  Decimal          @map("quantity_requested") @db.Decimal(10, 3)
  quantityProduced   Decimal          @default(0) @map("quantity_produced") @db.Decimal(10, 3)
  pendingAt          DateTime         @default(now()) @map("pending_at")
  startedAt          DateTime?        @map("started_at")
  completedAt        DateTime?        @map("completed_at")
  deliveredAt        DateTime?        @map("delivered_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@index([orderItemId])
  @@index([productionLocation])
  @@index([status])
  @@index([pendingAt])
  @@index([startedAt])
  @@index([completedAt])
  @@map("order_productions")
}

model Sale {
  id                           Int          @id @default(autoincrement())
  clientId                     Int          @map("client_id")
  client                       Client       @relation(fields: [clientId], references: [id])
  userOperator                 String       @map("user_operator")
  operatorId                   Int?         @map("operator_id")
  operator                     User?        @relation(fields: [operatorId], references: [id])
  date                         DateTime     @default(now())
  paymentMethod                String       @map("payment_method")
  totalProductsWithoutDiscount Decimal      @map("total_products_without_discount") @db.Decimal(10, 2)
  discount                     Decimal      @default(0) @db.Decimal(10, 2)
  total                        Decimal      @db.Decimal(10, 2)
  profitSale                   Decimal      @map("profit_sale") @db.Decimal(10, 2)
  isPaid                       Boolean      @default(false) @map("is_paid")
  cfop                         String       @default("5102")
  fiscalStatus                 FiscalStatus @default(PENDENTE) @map("fiscal_status")
  fiscalKey                    String?      @map("fiscal_key")
  fiscalProtocol               String?      @map("fiscal_protocol")
  fiscalEmitDate               DateTime?    @map("fiscal_emit_date")
  fiscalXml                    String?      @map("fiscal_xml") @db.LongText
  items                        SaleItem[]
  createdAt                    DateTime     @default(now()) @map("created_at")
  updatedAt                    DateTime     @updatedAt @map("updated_at")

  @@index([clientId])
  @@index([operatorId])
  @@index([date])
  @@index([fiscalStatus])
  @@index([fiscalKey])
  @@map("sales")
}

model SaleItem {
  id             Int      @id @default(autoincrement())
  itemNumber     Int      @map("item_number")
  saleId         Int      @map("sale_id")
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      Int      @map("product_id")
  product        Product  @relation(fields: [productId], references: [id])
  xProd          String?  @map("x_prod")
  quantity       Decimal  @db.Decimal(10, 3)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice     Decimal  @map("total_price") @db.Decimal(10, 2)
  taxUnit        String?  @map("tax_unit")
  taxQuantity    Decimal? @map("tax_quantity") @db.Decimal(10, 3)
  taxUnitPrice   Decimal? @map("tax_unit_price") @db.Decimal(10, 2)
  composesTotal  Int      @default(1) @map("composes_total")
  cfop           String?
  totalTaxValue  Decimal? @map("total_tax_value") @db.Decimal(10, 2)
  importTaxValue Decimal? @default(0) @map("import_tax_value") @db.Decimal(10, 2)
  iofValue       Decimal? @default(0) @map("iof_value") @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([saleId, itemNumber])
  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

model PrimaryMaterial {
  id               Int               @id @default(autoincrement())
  name             String
  code             String            @unique
  unit             Unit
  unitCost         Decimal           @map("unit_cost") @db.Decimal(10, 2)
  currentStock     Decimal           @default(0) @map("current_stock") @db.Decimal(10, 3)
  minStock         Decimal?          @map("min_stock") @db.Decimal(10, 3)
  expiryDate       DateTime?         @map("expiry_date")
  active           Boolean           @default(true)
  ncm              String?
  cfop             String?           @default("5102")
  compositionItems CompositionItem[]
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([code])
  @@index([active])
  @@map("primary_materials")
}

model CompositionItem {
  id           Int              @id @default(autoincrement())
  quantity     Decimal          @db.Decimal(10, 3)
  productId    Int              @map("product_id")
  product      Product          @relation("ProductComposition", fields: [productId], references: [id], onDelete: Cascade)
  materialId   Int?             @map("material_id")
  material     PrimaryMaterial? @relation(fields: [materialId], references: [id], onDelete: Restrict)
  subProductId Int?             @map("sub_product_id")
  subProduct   Product?         @relation("SubProductComposition", fields: [subProductId], references: [id], onDelete: Restrict)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@unique([productId, materialId])
  @@unique([productId, subProductId])
  @@index([productId])
  @@index([materialId])
  @@index([subProductId])
  @@map("composition_items")
}

model PreparationStep {
  id          Int      @id @default(autoincrement())
  order       Int
  description String   @db.Text
  productId   Int      @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([productId, order])
  @@index([productId])
  @@map("preparation_steps")
}

model Table {
  id         Int                @id @default(autoincrement())
  number     Int
  capacity   Int
  status     TableStatus        @default(AVAILABLE)
  customer   String?
  time       String?
  locationId Int                @map("location_id")
  location   ProductionLocation @relation(fields: [locationId], references: [id])
  orderId    Int?               @unique @map("order_id")
  order      Order?             @relation(fields: [orderId], references: [id])
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@unique([number, locationId])
  @@index([locationId])
  @@index([status])
  @@map("tables")
}
