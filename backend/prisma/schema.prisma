generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

model Company {
  id        Int      @id @default(autoincrement())
  name      String
  cnpj      String   @unique
  phone     String?
  email     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?  @map("zip_code")
  logo      String? // Logo URL
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  cpf       String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cpf])
  @@index([phone])
  @@index([active])
  @@map("clients")
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  password  String // Hash bcrypt
  role      String  @default("USER") // ADMIN, MANAGER, WAITER, CASHIER, KITCHEN
  active    Boolean @default(true)
  workplace String

  // Timestamps
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // Soft delete

  @@index([role])
  @@index([active])
  @@map("users")
}
